{
  "id": "bq-bridge",
  "type": "mcp",
  "description": "MCP server to safely inspect BigQuery metadata, run validation queries, and manage property graph definitions.",
  "requires": [],
  "suggests": [],
  "mcpConfig": {
    "mcpServers": {
      "bq-bridge": {
        "command": "npx",
        "args": [
          "-y",
          "@google-cloud/mcp-server-bigquery"
        ],
        "env": {
          "GCP_PROJECT": "gsk-onyx-ap",
          "GCP_LOCATION": "global"
        }
      }
    }
  }
}
